# =============================================================================
# 2025-Frict — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# .env is gitignored and must never be committed.
# =============================================================================

# Spring profile: "local" for development, "prod" for AWS deployment
SPRING_PROFILES_ACTIVE=local

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=Frict
MYSQL_USERNAME=user
MYSQL_PASSWORD=password

# --- MongoDB ---
MONGODB_URI=mongodb://user:password@localhost:27017/Frict?authSource=admin&directConnection=true

# --- JWT & Encryption ---
JWT_SECRET=
DB_ENCRYPTION_KEY=

# --- CORS ---
CORS_ALLOWED_ORIGIN=https://localhost:4202

# --- S3 / MinIO ---
APP_STORAGE_BUCKET_NAME=images
APP_STORAGE_REGION=us-east-1
# Only for local development with MinIO (leave empty in AWS — uses IAM task role):
APP_STORAGE_ENDPOINT=https://localhost:9000
APP_STORAGE_PUBLIC_URL=https://localhost:9000
AWS_ACCESS_KEY_ID=user
AWS_SECRET_ACCESS_KEY=password

# --- Email ---
SENDER_MAIL_PORT=587
SENDER_MAIL_ADDRESS=
SENDER_MAIL_PASSWORD=

# --- Google OAuth ---
GOOGLE_AUTH_CLIENT_ID=

# --- Geocoding ---
# Only for local (direct Nominatim). In prod, geocoding goes through Lambda.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=Frict-Backend/1.0 (contact@frict.local)

# --- Routing (OSRM) ---
OSRM_BASE_URL=https://router.project-osrm.org

# --- Lambda (prod only) ---
# LAMBDA_GEOCODING_NAME=frict-geocoding
