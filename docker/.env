# =============================================================================
# Frict — environment for docker-compose.yml (example / dummy values)
# =============================================================================
# Single self-contained env for the prod-like compose:
#   - IMAGE_TAG feeds ${IMAGE_TAG} interpolation in the compose file.
#   - The rest is injected into the app containers via `env_file: - .env`.
# Note: every other variable is already set inline in docker-compose.yml's
# `environment:` block, which takes precedence over this file.
# =============================================================================

# --- Image tag (used for ${IMAGE_TAG} in the compose file) ---
IMAGE_TAG=dev

# --- JWT & Encryption ---
JWT_SECRET=c3VwZXJfc2VjcmV0X2tleV9mb3JfZGV2ZWxvcG1lbnRfcHVycG9zZXNfb25seV8xMjM0NTY3ODkw
DB_ENCRYPTION_KEY=1234567890123456

# --- Email (leave address/password empty to disable real mail sending) ---
SENDER_MAIL_HOST=smtp.gmail.com
SENDER_MAIL_PORT=587
SENDER_MAIL_ADDRESS=
SENDER_MAIL_PASSWORD=

# --- Google OAuth (empty disables Google login) ---
GOOGLE_AUTH_CLIENT_ID=